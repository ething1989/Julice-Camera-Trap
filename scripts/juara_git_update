#!/usr/bin/env bash
set -u

REPO_URL="${JUARA_GIT_REPO_URL:-https://github.com/ething1989/Julice-Camera-Trap.git}"
BRANCH="${JUARA_GIT_BRANCH:-main}"
CHECKOUT_DIR="${JUARA_GIT_CHECKOUT_DIR:-/var/lib/juara-station/git/Julice-Camera-Trap}"
DEPLOY_DIR="${JUARA_DEPLOY_DIR:-/opt/juara-wildlife-station}"
BACKUP_DIR="${JUARA_UPDATE_BACKUP_DIR:-/var/lib/juara-station/update-backups}"
LOG_PATH="${JUARA_GIT_UPDATE_LOG:-/var/log/juara-git-update.log}"
APP_USER="${JUARA_SERVICE_USER:-${USER:-pi}}"
SKIP_BACKUP="${JUARA_SKIP_DEPLOY_BACKUP:-0}"
CONFIG_PATH="${JUARA_STATION_CONFIG:-/etc/juara-station.toml}"
GDRIVE_ENV="${JUARA_GDRIVE_ENV:-/etc/default/juara-gdrive-sync}"

log() {
  printf '%s %s\n' "$(date -Is)" "$*" | tee -a "$LOG_PATH" >/dev/null
}

trust_git_dir() {
  dir="$1"
  if [ -n "$dir" ]; then
    git config --global --get-all safe.directory | grep -Fx "$dir" >/dev/null 2>&1 || \
      git config --global --add safe.directory "$dir" >/dev/null 2>&1 || true
  fi
}

if ! command -v git >/dev/null 2>&1; then
  log "git is not installed"
  exit 0
fi

mkdir -p "$(dirname "$CHECKOUT_DIR")" "$BACKUP_DIR"
trust_git_dir "$CHECKOUT_DIR"
trust_git_dir "$DEPLOY_DIR"

if [ ! -d "$CHECKOUT_DIR/.git" ]; then
  log "cloning $REPO_URL branch $BRANCH"
  rm -rf "$CHECKOUT_DIR"
  if ! git clone --depth 1 --branch "$BRANCH" "$REPO_URL" "$CHECKOUT_DIR" >>"$LOG_PATH" 2>&1; then
    log "clone failed; keeping current deployment"
    exit 0
  fi
else
  log "checking for git updates in $CHECKOUT_DIR"
  git -C "$CHECKOUT_DIR" remote set-url origin "$REPO_URL" >>"$LOG_PATH" 2>&1 || true
  if ! git -C "$CHECKOUT_DIR" fetch --depth 1 origin "$BRANCH" >>"$LOG_PATH" 2>&1; then
    log "fetch failed; keeping current deployment"
    exit 0
  fi
  local_head="$(git -C "$CHECKOUT_DIR" rev-parse HEAD 2>/dev/null || true)"
  remote_head="$(git -C "$CHECKOUT_DIR" rev-parse "origin/$BRANCH" 2>/dev/null || true)"
  if [ -n "$local_head" ] && [ "$local_head" = "$remote_head" ]; then
    log "already up to date at $local_head"
    exit 0
  fi
  if ! git -C "$CHECKOUT_DIR" reset --hard "origin/$BRANCH" >>"$LOG_PATH" 2>&1; then
    log "reset failed; keeping current deployment"
    exit 0
  fi
fi

new_head="$(git -C "$CHECKOUT_DIR" rev-parse HEAD 2>/dev/null || echo unknown)"
stamp="$(date -u +%Y%m%dT%H%M%SZ)"

if [ "$SKIP_BACKUP" = "1" ]; then
  log "skipping deploy backup because JUARA_SKIP_DEPLOY_BACKUP=1"
elif [ -d "$DEPLOY_DIR" ]; then
  backup="$BACKUP_DIR/juara-wildlife-station-$stamp"
  log "backing up $DEPLOY_DIR to $backup"
  mkdir -p "$backup"
  rsync -a --delete \
    --exclude '.git/' \
    --exclude '.venv/' \
    --exclude '__pycache__/' \
    --exclude '*.pyc' \
    --exclude 'models/' \
    "$DEPLOY_DIR/" "$backup/" >>"$LOG_PATH" 2>&1 || true
fi

log "deploying $new_head to $DEPLOY_DIR"
mkdir -p "$DEPLOY_DIR"
rsync -a --delete \
  --exclude '.git/' \
  --exclude '.venv/' \
  "$CHECKOUT_DIR/" "$DEPLOY_DIR/" >>"$LOG_PATH" 2>&1

if [ -x "$DEPLOY_DIR/.venv/bin/python" ]; then
  "$DEPLOY_DIR/.venv/bin/python" -m pip install -e "$DEPLOY_DIR[pi,birdnet]" >>"$LOG_PATH" 2>&1 || \
    "$DEPLOY_DIR/.venv/bin/python" -m pip install -e "$DEPLOY_DIR" >>"$LOG_PATH" 2>&1 || true
  "$DEPLOY_DIR/.venv/bin/python" - <<'PY' >>"$LOG_PATH" 2>&1
from juara_station.config import load_config
load_config("/etc/juara-station.toml")
print("config import ok")
PY
fi

if [ -f "$CONFIG_PATH" ]; then
  CONFIG_PATH="$CONFIG_PATH" GDRIVE_ENV="$GDRIVE_ENV" python3 <<'PY' >>"$LOG_PATH" 2>&1 || true
from pathlib import Path
import os
import re
import shutil
from datetime import datetime, timezone

config = Path(os.environ["CONFIG_PATH"])
text = config.read_text()
lines = text.splitlines()
out = []
section = ""
changed = []
time_has_radius = False

def backup_once():
    backup = config.with_name(config.name + ".git-update-" + datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ"))
    shutil.copy2(config, backup)
    changed.insert(0, f"backup={backup}")

def leave_time_section(next_section=None):
    global time_has_radius
    if section == "time" and not time_has_radius:
        out.append("species_area_radius_km = 100.0")
        changed.append("inserted time.species_area_radius_km=100.0")
        time_has_radius = True
    if next_section is not None:
        out.append(next_section)

for line in lines:
    stripped = line.strip()
    if stripped.startswith("[") and stripped.endswith("]"):
        leave_time_section(line)
        section = stripped.strip("[]").strip()
        if section == "time":
            time_has_radius = False
        continue
    if section == "storage" and re.match(r'^\s*root\s*=\s*"/mnt/juara_usb(/juara)?"\s*$', line):
        out.append('root = "/var/lib/juara-station/local"')
        changed.append("migrated storage.root to /var/lib/juara-station/local")
        continue
    if section == "time" and re.match(r"^\s*species_area_radius_km\s*=", line):
        time_has_radius = True
    out.append(line)

leave_time_section()
new_text = "\n".join(out) + ("\n" if text.endswith("\n") else "")
if changed:
    backup_once()
    config.write_text(new_text)
    print("config migration changed: " + "; ".join(changed))
else:
    print("config migration unchanged")

gdrive_env = Path(os.environ["GDRIVE_ENV"])
if gdrive_env.exists():
    original = gdrive_env.read_text()
    updated = re.sub(r"^JUARA_LOCAL_ROOT=.*$", "JUARA_LOCAL_ROOT=/var/lib/juara-station/local", original, flags=re.MULTILINE)
    if "JUARA_LOCAL_ROOT=" not in updated:
        updated += "\nJUARA_LOCAL_ROOT=/var/lib/juara-station/local\n"
    updated = re.sub(
        r"^JUARA_GDRIVE_DIR=([^\"'\n]*\s[^\"'\n]*)$",
        lambda match: f'JUARA_GDRIVE_DIR="{match.group(1)}"',
        updated,
        flags=re.MULTILINE,
    )
    if updated != original:
        gdrive_env.write_text(updated)
        print(f"updated {gdrive_env} local root")
PY
fi

systemctl restart juara-station.service juara-ai-worker.service >>"$LOG_PATH" 2>&1 || true
log "update complete at $new_head for $APP_USER"
